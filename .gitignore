# Credentials — must never be committed
*creds*.json
*credentials*.json
.env
.env.*
credentials/
*.pem
*.key

# Raw Arccos cache (contains GPS + PII; lives in ~/golf-data anyway, but defensive)
arccos_raw/
golf-data/
*_raw.json

# GHIN / 18Birdies sync artifacts (PII)
ghin_*.json
ghin_*.csv
eighteenbirdies_*.json

# Notebook checkpoints + jupyter cruft
.ipynb_checkpoints/
*.ipynb_checkpoints

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/
env/

# Playwright MCP transient artifacts (snapshots, screenshots, console logs)
.playwright-mcp/

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini

# OneDrive sync detritus
.tmp.driveupload/
*-conflicted copy*
~$*.xlsx
~$*.docx
~$*.pptx

# Cached source PDFs (large; re-downloadable via pipeline, hashes tracked in manifest)
data/irons_research/*.pdf
data/irons_research/brand_pdfs/
# Raw scraping artifacts (large screenshots/article text); small mgs_*.json kept for repeatability
data/irons_research/raw/*.png
data/irons_research/raw/*.txt
# Cool Clubs images (re-downloadable via fetch_coolclubs_iron_data.py; values captured in coolclubs_iron_data.csv)
data/irons_research/coolclubs/png/

# Local secrets / scratch
scratch/
local/
.vscode/
.idea/
